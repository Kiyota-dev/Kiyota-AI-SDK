{
  "name": "@kiyota/sdk",
  "version": "0.5.0",
  "description": "The Kiyota AI SDK — one install, every model.",
  "license": "MIT",
  "author": "Kiyota",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js",
      "require": "./dist/models.cjs"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.js",
      "require": "./dist/providers/openai.cjs"
    },
    "./providers/anthropic": {
      "types": "./dist/providers/anthropic.d.ts",
      "import": "./dist/providers/anthropic.js",
      "require": "./dist/providers/anthropic.cjs"
    },
    "./providers/kimi": {
      "types": "./dist/providers/kimi.d.ts",
      "import": "./dist/providers/kimi.js",
      "require": "./dist/providers/kimi.cjs"
    },
    "./providers/deepseek": {
      "types": "./dist/providers/deepseek.d.ts",
      "import": "./dist/providers/deepseek.js",
      "require": "./dist/providers/deepseek.cjs"
    },
    "./providers/mistral": {
      "types": "./dist/providers/mistral.d.ts",
      "import": "./dist/providers/mistral.js",
      "require": "./dist/providers/mistral.cjs"
    },
    "./providers/minimax": {
      "types": "./dist/providers/minimax.d.ts",
      "import": "./dist/providers/minimax.js",
      "require": "./dist/providers/minimax.cjs"
    },
    "./providers/xai": {
      "types": "./dist/providers/xai.d.ts",
      "import": "./dist/providers/xai.js",
      "require": "./dist/providers/xai.cjs"
    },
    "./providers/qwen": {
      "types": "./dist/providers/qwen.d.ts",
      "import": "./dist/providers/qwen.js",
      "require": "./dist/providers/qwen.cjs"
    },
    "./providers/gemini": {
      "types": "./dist/providers/gemini.d.ts",
      "import": "./dist/providers/gemini.js",
      "require": "./dist/providers/gemini.cjs"
    },
    "./providers/nvidia": {
      "types": "./dist/providers/nvidia.d.ts",
      "import": "./dist/providers/nvidia.js",
      "require": "./dist/providers/nvidia.cjs"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "ai",
    "llm",
    "kiyota",
    "openai",
    "sdk",
    "generate-text",
    "embeddings"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kiyota-dev/Kiyota-AI-SDK.git",
    "directory": "packages/sdk"
  },
  "scripts": {
    "build": "tsup src/index.ts src/models.ts src/providers/*.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "prepack": "node ../../scripts/prepack.js",
    "postpack": "node ../../scripts/postpack.js"
  },
  "dependencies": {
    "@kiyota/client": "workspace:*",
    "@kiyota/core": "workspace:*",
    "@kiyota/events": "workspace:*",
    "@kiyota/registry": "workspace:*",
    "@kiyota/provider-anthropic": "workspace:*",
    "@kiyota/provider-deepseek": "workspace:*",
    "@kiyota/provider-gemini": "workspace:*",
    "@kiyota/provider-kimi": "workspace:*",
    "@kiyota/provider-minimax": "workspace:*",
    "@kiyota/provider-mistral": "workspace:*",
    "@kiyota/provider-nvidia": "workspace:*",
    "@kiyota/provider-openai": "workspace:*",
    "@kiyota/provider-qwen": "workspace:*",
    "@kiyota/provider-utils": "workspace:*",
    "@kiyota/provider-xai": "workspace:*"
  },
  "devDependencies": {
    "@kiyota/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
